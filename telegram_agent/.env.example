# Copia este archivo como .env y rellena los valores

# Token de tu bot (lo da @BotFather en Telegram)
TELEGRAM_TOKEN=123456789:ABCdefGhIjKlmNoPQRsTuVwXyZ

# API Key de Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Opcional: IDs de Telegram separados por coma para limitar acceso
# Déjalo vacío para que cualquiera pueda usar el bot
# Para saber tu ID habla con @userinfobot en Telegram
ALLOWED_USERS=
