# ── Credenciales ──────────────────────────────────────────────────────────────

# Token del bot de Telegram (lo da @BotFather)
TELEGRAM_TOKEN=123456789:ABCdefGhIjKlmNoPQRsTuVwXyZ

# API Key de Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# ── Acceso ────────────────────────────────────────────────────────────────────

# IDs de Telegram separados por coma para limitar acceso.
# Dejar vacío = abierto a todos. Para saber tu ID habla con @userinfobot.
ALLOWED_USERS=

# ── Agente ────────────────────────────────────────────────────────────────────

# Tiempo máximo (segundos) que puede tardar el agente en responder
AGENT_TIMEOUT=120

# Máximo de mensajes guardados en contexto por sesión (ventana deslizante)
CONTEXT_WINDOW=40

# Máximo de pasos/iteraciones del loop agéntico
MAX_AGENT_STEPS=10

# ── Rate limiting ─────────────────────────────────────────────────────────────

# Máx mensajes permitidos por sesión dentro de la ventana de tiempo
RATE_LIMIT_MSGS=10
# Ventana de tiempo en segundos
RATE_LIMIT_WINDOW=60

# ── Webchat ───────────────────────────────────────────────────────────────────

# Host y puerto del servidor web
WEB_HOST=0.0.0.0
WEB_PORT=8080
