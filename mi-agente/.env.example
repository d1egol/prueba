TELEGRAM_TOKEN=pega_aqui_el_token_de_botfather
ANTHROPIC_API_KEY=pega_aqui_tu_api_key_de_anthropic

# Opcional: IDs de Telegram autorizados (separados por coma)
# Para saber tu ID habla con @userinfobot en Telegram
# Si está vacío, cualquiera puede usar el bot
ALLOWED_USERS=

# ── Configuración de email para reporte diario PDF ──────────────────────────
# Requerido para recibir el reporte diario en tu correo.
# Para Gmail: activa "App Passwords" en tu cuenta Google y usa esa contraseña.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password_de_gmail
REPORT_EMAIL=dilopezd91@gmail.com

# ── Rate limiting ────────────────────────────────────────────────────────────
# Máximo de mensajes por hora por usuario (default: 30)
RATE_LIMIT=30
